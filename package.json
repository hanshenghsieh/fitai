{
  "name": "fitness-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "import-menu": "node scripts/import-menu.js",
    "sync-menu": "node scripts/sync-menu.mjs",
    "food-kb:sync": "npx tsx scripts/food-kb/pipeline.ts",
    "food-kb:build-seeds": "npx tsx scripts/food-kb/build-category-seeds.ts",
    "food-kb:coverage": "npx tsx scripts/food-kb/coverage-report.ts",
    "food-kb:dashboard": "npx tsx scripts/food-kb/dashboard.ts",
    "food-kb:export": "npx tsx scripts/food-kb/export-runtime.ts",
    "food-kb:xval": "npx tsx scripts/food-kb/strict-xval.ts",
    "food-kb:apply-conflicts": "npx tsx scripts/food-kb/apply-conflict-patches.ts",
    "food-kb:full": "npm run food-kb:build-seeds && npm run food-kb:sync && npm run sync-menu",
    "food-kb:strict": "npm run food-kb:xval && npm run food-kb:apply-conflicts && npm run food-kb:build-seeds && npm run food-kb:sync -- --adapters category-seeds,official-nutrition,blog-nutrition && npm run sync-menu",
    "food-kb:bulk-dice": "npx tsx scripts/food-kb/generate-bulk-dice-menu.ts",
    "market-lab:500": "npx tsx scripts/market-reality-lab-500/run.ts",
    "mr500:goal-visibility": "npx tsx scripts/market-reality-lab-500/run-goal-visibility.ts",
    "food-photo:verify": "npx tsx scripts/food-photo-verify.ts",
    "food-images:setup": "npx tsx scripts/setup-food-images.ts",
    "food-images:reset": "npx tsx scripts/setup-food-images.ts -- --force",
    "market-loop": "npx tsx scripts/market-loop/run.ts",
    "test": "node --import tsx --test src/lib/engines/calorie-bank-engine.test.ts",
    "migrate:calorie-bank": "node scripts/apply-calorie-bank-migration.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.2",
    "@base-ui/react": "^1.5.0",
    "@hookform/resolvers": "^5.4.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "firebase": "^12.15.0",
    "firebase-admin": "^14.0.0",
    "lucide-react": "^1.18.0",
    "next": "16.2.9",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.79.0",
    "recharts": "^3.8.0",
    "shadcn": "^4.11.0",
    "sonner": "^2.0.7",
    "stripe": "^22.2.1",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "pg": "^8.22.0",
    "puppeteer": "^25.1.0",
    "tailwindcss": "^4",
    "tsx": "^4.19.4",
    "typescript": "^5"
  }
}
