{
  "name": "fitness-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "import-menu": "node scripts/import-menu.js",
    "sync-menu": "node scripts/sync-menu.mjs",
