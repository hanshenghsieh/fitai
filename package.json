    "food-kb:strict": "npm run food-kb:xval && npm run food-kb:apply-conflicts && npm run food-kb:build-seeds && npm run food-kb:sync -- --adapters category-seeds,official-nutrition,blog-nutrition && npm run sync-menu",
    "food-kb:bulk-dice": "npx tsx scripts/food-kb/generate-bulk-dice-menu.ts",
