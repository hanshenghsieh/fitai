    "verify:restaurant-menu": "npx tsx scripts/verify-restaurant-menu-data.ts",
    "qa:recommendation": "npx tsx scripts/run-recommendation-qa.ts",
    "qa:recommendation:bulk": "npx tsx scripts/run-recommendation-qa.ts --with-bulk",
    "qa:backfill": "npx tsx scripts/menu-backfill/acceptance-report.ts",
    "nutrition:trace": "npx tsx scripts/nutrition/trace-audit.ts",
    "food-intelligence:layer": "npx tsx scripts/run-food-intelligence-layer.ts",
    "backfill:list-missing": "npx tsx scripts/menu-backfill/list-missing-restaurants.ts",
    "backfill:sprint-1": "npx tsx scripts/menu-backfill/sprint-1-build.ts",
    "backfill:sprint-2": "npx tsx scripts/menu-backfill/sprint-2-build.ts",
    "backfill:sprint-3": "npx tsx scripts/menu-backfill/scaffold-sprint-3-brands.ts && npx tsx scripts/menu-backfill/sprint-3-build.ts",
    "backfill:sprint-4": "npx tsx scripts/menu-backfill/scaffold-sprint-4-brands.ts && npx tsx scripts/menu-backfill/sprint-4-build.ts",
    "backfill:sprint-5": "npx tsx scripts/menu-backfill/scaffold-sprint-5-brands.ts && npx tsx scripts/menu-backfill/sprint-5-build.ts",
    "onr:audit-sprint-4": "npx tsx scripts/nutrition/audit-onr-sprint-4.ts",
    "backfill:promote": "npx tsx scripts/menu-backfill/promote-to-runtime.ts --founder-approved",
    "onr:seed": "npx tsx scripts/nutrition/seed-official-reference.ts",
    "onr:coverage": "npx tsx scripts/nutrition/run-onr-coverage.ts",
    "bdgs:report": "npx tsx scripts/run-data-governance-report.ts",
    "qa:buttons": "node scripts/qa/scan-buttons.mjs",
    "migrate:calorie-bank": "node scripts/apply-calorie-bank-migration.mjs",
    "migrate:growth-posts": "node scripts/apply-growth-posts-migration.mjs",
    "growth:setup": "node scripts/print-growth-migration.mjs",
    "cap:sync": "npx cap sync ios",
    "cap:open:ios": "npx cap open ios",
    "cap:ios": "npx cap sync ios && npx cap open ios",
    "testflight:prep": "node scripts/testflight-prep.mjs",
    "testflight:3a-prep": "node scripts/testflight-build-3a-prep.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.2",
    "@base-ui/react": "^1.5.0",
